# TSP Production Environment — example variable values
# Copy to terraform.tfvars and adjust before terraform plan/apply.
# Do NOT commit terraform.tfvars (contains environment-specific values).

aws_region                  = "us-east-1"
aws_skip_credential_checks  = false
environment                 = "production"
service_name                = "tsp-production"

# Broke-mode PE: ec2 (default). Use apprunner only after IAM + App Runner subscription are resolved.
compute_platform = "ec2"
ec2_instance_type = "t3.micro"
ec2_image_source  = "docker_hub"
ec2_host_port     = 80

# Docker Hub source (EC2 pull; optional mirror to ECR)
docker_hub_image = "taig2k/taig_service_portal_tsp"
docker_image_tag = "deployable"

# ECR repository (created by Terraform; App Runner pulls from here)
ecr_repository_name = "taig-service-portal-tsp"
image_repository_type = "ECR"

application_port = 3000

auto_deployments_enabled = false

cpu    = "256"
memory = "512"

max_concurrency = 100
min_size        = 1
max_size        = 2

health_check_path                = "/health"
health_check_interval            = 10
health_check_timeout             = 5
health_check_healthy_threshold   = 1
health_check_unhealthy_threshold = 3

runtime_environment_variables = {}

tags = {
  ACI = "PE-004B"
}
